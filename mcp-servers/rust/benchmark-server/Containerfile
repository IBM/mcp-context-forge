# syntax=docker/dockerfile:1
FROM docker.io/library/rust:1.86-slim AS builder

WORKDIR /app

# Copy the entire benchmark-server directory (build context is this directory)
COPY . ./

# Build benchmark-server using its standalone workspace
RUN cargo build --release

FROM docker.io/library/debian:trixie-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/* \
    && useradd -r -s /bin/false mcpuser
WORKDIR /app
COPY --from=builder /app/target/release/benchmark-server /app/benchmark-server
USER mcpuser
EXPOSE 8080
ENV RUST_LOG=info
LABEL org.opencontainers.image.title="benchmark-server"
LABEL org.opencontainers.image.description="Configurable MCP benchmark server in Rust"
LABEL org.opencontainers.image.source="https://github.com/IBM/mcp-context-forge"
LABEL org.opencontainers.image.vendor="IBM"
LABEL org.opencontainers.image.licenses="Apache-2.0"
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -sf http://localhost:8080/health || exit 1
ENTRYPOINT ["/app/benchmark-server"]
