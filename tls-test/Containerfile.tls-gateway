# Derivative gateway image for the TLS-Redis smoke test.
#
# Single change vs. the upstream mcpgateway/mcpgateway:latest base image:
# trust the local self-signed CA at ../tls-certs/ca.crt by adding it to the
# OS trust store via UBI's update-ca-trust mechanism. The plugin uses
# rustls-native-certs, which reads the same store, so this enables the TLS
# handshake against our test redis service.
#
# No wheel surgery: cpex-rate-limiter >= 0.0.6 (TLS-enabled, from PyPI) is
# already installed by the base image's `[plugins]` extra.

ARG BASE_IMAGE=mcpgateway/mcpgateway:latest

FROM ${BASE_IMAGE}

USER root

# Trust the local test CA. UBI's update-ca-trust reads
# /etc/pki/ca-trust/source/anchors/ and rebuilds /etc/pki/tls/certs/ca-bundle.crt
# (which rustls-native-certs reads) to include any anchors found there.
COPY tls-certs/ca.crt /etc/pki/ca-trust/source/anchors/cpex-tls-test-ca.crt
RUN update-ca-trust extract

USER 1001
